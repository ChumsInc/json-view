{
  "name": "@chumsinc/json-view",
  "version": "2.0.0",
  "description": "Chums JSONView Component",
  "main": "dist/index.umd.js",
  "module": "dist/index.es.js",
  "source": "src/index.ts",
  "types": "./dist/types/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/index.es.js"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/index.umd.js"
      }
    }
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "version": "auto-changelog -p && git add CHANGELOG.md"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UtahGooner/json-view.git"
  },
  "author": "Steve Montgomery",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/UtahGooner/json-view/issues"
  },
  "homepage": "https://github.com/UtahGooner/json-view#readme",
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@tsconfig/node18": "^18.2.4",
    "@types/base16": "^1.0.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "auto-changelog": "^2.4.0",
    "bootstrap": "^5.1.3",
    "copyfiles": "^2.4.1",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.0.4",
    "typescript-eslint": "^8.35.1",
    "vite": "^8.0.5"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "auto-changelog": {
    "template": "changelog-template.hbs",
    "unreleased": true,
    "commitLimit": false,
    "breakingPattern": "BREAKING CHANGE:"
  },
  "dependencies": {
    "@emotion/styled": "^11.14.1",
    "base16": "^1.0.0",
    "classnames": "^2.3.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "directories": {
    "test": "test"
  },
  "keywords": [
    "JSON",
    "view"
  ]
}
