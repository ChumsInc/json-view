{
  "name": "@chumsinc/json-view",
  "version": "2.1.0",
  "type": "module",
  "description": "Chums JSONView Component",
  "source": "./src/index.tsx",
  "main": "./dist/json-view.cjs",
  "module": "./dist/json-view.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/json-view.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/json-view.cjs"
      }
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build-vite && npm run build-dts",
    "build-vite": "vite build",
    "build-dts": "tsc -p tsconfig-build.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "version": "auto-changelog -p && git add CHANGELOG.md"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UtahGooner/json-view.git"
  },
  "author": "Steve Montgomery",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/UtahGooner/json-view/issues"
  },
  "homepage": "https://github.com/UtahGooner/json-view#readme",
  "devDependencies": {
    "@chumsinc/ui-utils": "^2.1.4",
    "@eslint/js": "^10.0.1",
    "@tsconfig/node18": "^18.2.4",
    "@types/base16": "^1.0.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "auto-changelog": "^2.4.0",
    "bootstrap": "^5.1.3",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.5"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "auto-changelog": {
    "template": "changelog-template.hbs",
    "unreleased": true,
    "commitLimit": false,
    "breakingPattern": "BREAKING CHANGE:"
  },
  "dependencies": {
    "@emotion/styled": "^11.14.1",
    "base16": "^1.0.0",
    "classnames": "^2.3.1"
  },
  "directories": {
    "test": "test"
  },
  "keywords": [
    "JSON",
    "view"
  ]
}
